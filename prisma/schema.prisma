generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  admin
  user
}

enum TenderStatus {
  activa
  por_cobrar
  perdida
  finalizada
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(user)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  createdClients   Client[]  @relation("createdClients")
  updatedClients   Client[]  @relation("updatedClients")
  createdProducts  Product[] @relation("createdProducts")
  updatedProducts  Product[] @relation("updatedProducts")
  createdTenders   Tender[]  @relation("createdTenders")
  updatedTenders   Tender[]  @relation("updatedTenders")

  @@map("users")
}

model Client {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String
  company   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Foreign keys
  createdById Int
  updatedById Int?

  // Relations
  createdBy User  @relation("createdClients", fields: [createdById], references: [id])
  updatedBy User? @relation("updatedClients", fields: [updatedById], references: [id])
  tenders   Tender[]

  @@map("clients")
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  sku         String   @unique
  unitPrice   Decimal  @db.Decimal(10, 2)
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Foreign keys
  createdById Int
  updatedById Int?

  // Relations
  createdBy      User             @relation("createdProducts", fields: [createdById], references: [id])
  updatedBy      User?            @relation("updatedProducts", fields: [updatedById], references: [id])
  tenderProducts TenderProduct[]

  @@map("products")
}

model Tender {
  id          Int          @id @default(autoincrement())
  title       String
  description String
  maxBudget   Decimal      @db.Decimal(10, 2)
  totalAmount Decimal      @default(0) @db.Decimal(10, 2)
  status      TenderStatus @default(activa)
  startDate   DateTime
  endDate     DateTime
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Foreign keys
  clientId    Int
  createdById Int
  updatedById Int?

  // Relations
  client         Client          @relation(fields: [clientId], references: [id])
  createdBy      User            @relation("createdTenders", fields: [createdById], references: [id])
  updatedBy      User?           @relation("updatedTenders", fields: [updatedById], references: [id])
  tenderProducts TenderProduct[]

  @@map("tenders")
}

model TenderProduct {
  id        Int     @id @default(autoincrement())
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)

  // Foreign keys
  tenderId  Int
  productId Int

  // Relations
  tender  Tender  @relation(fields: [tenderId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([tenderId, productId])
  @@map("tender_products")
}
